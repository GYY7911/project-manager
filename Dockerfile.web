# ===== Next.js 前端 =====
FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app

# ===== Stage 2: Build =====
FROM base AS builder

COPY .npmrc.docker .npmrc

# 拷贝 workspace 配置
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json turbo.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/web/package.json apps/web/

# 安装依赖
RUN pnpm install --frozen-lockfile

# 拷贝源码
COPY packages/shared/ packages/shared/
COPY apps/web/ apps/web/

# 构建 shared 包
RUN TSC=$(find /app/node_modules/.pnpm -path "*/typescript/bin/tsc" | head -1) && \
    node "$TSC" --project packages/shared/tsconfig.json && \
    sed -i 's|"main": "./src/index.ts"|"main": "./dist/index.js"|' packages/shared/package.json

# 构建 Next.js
ENV DOCKER_BUILD=1
RUN NEXT=$(find /app/node_modules/.pnpm -path "*/next/dist/bin/next" | head -1) && \
    cd apps/web && node "$NEXT" build

# ===== Stage 3: Production =====
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
EXPOSE 4000
ENV HOSTNAME="0.0.0.0"
ENV PORT=4000

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

CMD ["node", "apps/web/server.js"]
